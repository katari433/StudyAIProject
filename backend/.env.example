# StudyAI Backend Environment Configuration
# Copy this file to .env and fill in your actual values for local development

## Database Configuration
# Connection string for the database
# For SQLite (local development): sqlite:///./studyai.db
# For PostgreSQL (production): postgresql://username:password@localhost:5432/studyai_db
DATABASE_URL=sqlite:///./studyai.db

## Security & Authentication
# Secret key for JWT token signing (use a cryptographically secure random string in production)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-me-in-production

# JWT token expiration time in minutes (default: 30 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

## AI Integration
# API key for OpenAI GPT integration
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use for AI generation (gpt-3.5-turbo or gpt-4)
AI_MODEL=gpt-3.5-turbo

# Timeout for AI API calls in seconds
AI_REQUEST_TIMEOUT=30

# Maximum tokens for AI responses
AI_MAX_TOKENS=2000

## Application Settings
# Environment: development, staging, production
ENVIRONMENT=development

# FastAPI debug mode (True for development, False for production)
DEBUG=True

# CORS allowed origins (comma-separated for multiple origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Database connection pool settings (for PostgreSQL)
# Uncomment these for production with PostgreSQL
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

## Logging
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

## MCP Server Integration
# If using Model Context Protocol (MCP) for extended functionality
# MCP_SERVER_URL=http://localhost:3001
# MCP_API_KEY=your-mcp-api-key

## Optional: Email Configuration (for future user notifications)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@studyai.com

## Optional: Rate Limiting
# Maximum requests per minute from a single IP
# RATE_LIMIT_REQUESTS_PER_MINUTE=60

## Development-Only Settings
# Local SQLite database path (used if DATABASE_URL not specified)
# SQLITE_DB_PATH=./studyai.db
